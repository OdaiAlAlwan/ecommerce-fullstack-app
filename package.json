{
  "name": "ecommerce-fullstack-app",
  "version": "1.0.0",
  "description": "Monorepo root",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend/app",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend/app",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
